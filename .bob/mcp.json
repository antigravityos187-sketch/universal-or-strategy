{
  "mcpServers": {
    "greptile": {
      "url": "https://api.greptile.com/mcp",
      "type": "streamable-http",
      "headers": {
        "Authorization": "Bearer ${GREPTILE_API_KEY}"
      },
      "alwaysAllow": ["query", "search", "search_codebase", "query_codebase", "semantic_search"]
    }
  }
}